DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/face_smart

POSTGRES_DB=face_smart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=face_embeddings
MILVUS_VECTOR_DIM=512
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_SEARCH_EF=64
MILVUS_TOP_K=1

MIRROR_EMBEDDING_TO_POSTGRES=true
